# NutriSense AI — Environment Variables
# Copy this file to .env and fill in your real values.
# NEVER commit .env to version control.

# ── Backend ────────────────────────────────────────────────────────────
# Google Gemini API key (from Google AI Studio: https://aistudio.google.com)
GEMINI_API_KEY=your_gemini_api_key_here

# Google Maps & Places API key (enable Maps JS API + Places API in Cloud Console)
MAPS_API_KEY=your_maps_api_key_here

# Path to your Firebase service account JSON (download from Firebase Console)
FIREBASE_SERVICE_ACCOUNT_PATH=./firebase-service-account.json

# ── Frontend (prefix REACT_APP_ so CRA exposes them to the browser) ────
REACT_APP_API_URL=http://localhost:8000/api

# Firebase Web App config (from Firebase Console → Project Settings → Your apps)
REACT_APP_FIREBASE_API_KEY=your_firebase_web_api_key_here
REACT_APP_FIREBASE_AUTH_DOMAIN=your_project_id.firebaseapp.com
REACT_APP_FIREBASE_PROJECT_ID=your_project_id_here
REACT_APP_FIREBASE_STORAGE_BUCKET=your_project_id.appspot.com
REACT_APP_FIREBASE_MESSAGING_SENDER_ID=your_sender_id_here
REACT_APP_FIREBASE_APP_ID=your_firebase_app_id_here

# Google Maps JS API key for the frontend map widget
REACT_APP_MAPS_API_KEY=your_maps_api_key_here
